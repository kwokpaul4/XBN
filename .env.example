# -----------------------------------------------------------------------
# XBN environment reference (PHASES.md §5.3).
#
# Copy this file to `.env` and adjust for your target. Every variable used
# by the API or web portal is listed here — the shape (not the secrets).
# For local dev the defaults in docker-compose.yml already work; only set
# overrides if you're pointing at a different DB / MinIO / SMTP.
# -----------------------------------------------------------------------

# --- Node process ------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug               # pino level: trace | debug | info | warn | error
API_PORT=3000
WEB_PORT=5173

# --- Database ----------------------------------------------------------
DATABASE_URL=postgresql://xbn:xbn_dev@localhost:5432/xbn
# The API test suite truncates tables on beforeEach; usually the same DB.
TEST_DATABASE_URL=postgresql://xbn:xbn_dev@localhost:5432/xbn

# --- Attachment storage (MinIO / S3) -----------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=xbn
S3_SECRET_KEY=xbn_dev_minio
S3_BUCKET=xbn-attachments

# --- Email (Phase 4.5 writes to notification_outbox today; the pg-boss
#     SMTP consumer is Phase 5.4 wire-up work).
SMTP_HOST=localhost
SMTP_PORT=1025                # MailHog: 1025 = smtp, 8025 = web UI
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@xbn.local

# --- Auth (Lucia session — the API sets its own httpOnly xbn_session
#     cookie at /auth/login. JWT_SECRET is reserved for future OIDC
#     bridging; not read by the current code path.)
JWT_SECRET=replace-me-with-a-long-random-string

# --- API + web ---------------------------------------------------------
API_BASE_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:3000
