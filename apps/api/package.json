{
  "name": "@xbn/api",
  "version": "0.0.0",
  "private": true,
  "description": "XBN API — Express 5 HTTP surface composing @xbn/auth, @xbn/network, @xbn/document-core",
  "type": "module",
  "main": "./src/main.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@xbn/auth": "workspace:*",
    "@xbn/db": "workspace:*",
    "@xbn/document-core": "workspace:*",
    "@xbn/network": "workspace:*",
    "@xbn/shared-types": "workspace:*",
    "cookie-parser": "^1.4.7",
    "express": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.2"
  }
}
