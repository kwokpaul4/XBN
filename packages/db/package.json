{
  "name": "@xbn/db",
  "version": "0.0.0",
  "private": true,
  "description": "Prisma schema and client for XBN. Phase 1 schema covers Org/User/TradingRelationship and the document substrate (documents, document_versions, document_links, document_audit_log, attachments, notification_outbox).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:format": "prisma format"
  },
  "devDependencies": {
    "prisma": "^7.8.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.2"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0"
  }
}
